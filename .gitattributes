# Default: auto line endings
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf

# Windows-only scripts use CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Source and config files: LF everywhere
*.cpp text eol=lf
*.h   text eol=lf
*.qml text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Binary files: no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.mp3 binary
*.mp4 binary
*.avi binary
*.flac binary
*.ogg binary
*.wav binary
*.aac binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary
*.fbx binary
*.glb binary
*.stl binary
